# ── Werewolf Game Server — environment variables ──────────────────────────────
#
# Copy this file to .env and fill in values for your deployment.
# Never commit .env to version control.

# Port the HTTP + WebSocket server listens on.
# Railway and Render inject PORT automatically — do not set it there.
# For local dev or VPS, set SERVER_PORT (PORT also works).
SERVER_PORT=3001

# Allowed frontend origin(s). Comma-separated for multiple.
# Local dev:
CLIENT_ORIGIN=http://localhost:3000
# Production (Vercel example):
# CLIENT_ORIGIN=https://your-game.vercel.app

# Node environment — set to "production" on deployed servers.
NODE_ENV=development

# Enable test bot controls (host can fill rooms with AI bots for testing).
# Set to "true" in dev/staging only. Do NOT set in production.
# ENABLE_TEST_BOTS=true

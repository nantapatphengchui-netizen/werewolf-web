# ── Werewolf Game Client — environment variables ──────────────────────────────
#
# Copy this file to .env.local for local development.
# On Vercel, set these in the project's Environment Variables dashboard.
# Never commit .env.local to version control.

# Full URL of the game server (no trailing slash).
# Local dev:
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
# Production (Railway/Render example):
# NEXT_PUBLIC_SOCKET_URL=https://your-backend.up.railway.app
